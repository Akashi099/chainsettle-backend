# ============================================================
# ChainSettle Backend — Environment Variables
# Copy this to .env and fill in your values
# Variables marked [required] must be set; others have defaults.
# ============================================================

# ── Server ───────────────────────────────────────────────────
# [optional] Application environment. Values: development | production | test
NODE_ENV=development

# [optional] Port the HTTP server listens on (default: 3000)
PORT=3000

# [optional] Global API route prefix (default: api/v1)
API_PREFIX=api/v1

# ── JWT Auth ─────────────────────────────────────────────────
# [required] Secret used to sign JWT tokens. Use a long random string in production.
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# [optional] Token lifetime (default: 7d). Accepts zeit/ms format.
JWT_EXPIRES_IN=7d

# ── Database (PostgreSQL via Prisma) ─────────────────────────
# [required] Full PostgreSQL connection string. Must start with postgresql:// or postgres://
DATABASE_URL=postgresql://chainsetttle:password@localhost:5432/chainsetttle_db

# [optional] Max simultaneous connections in the Prisma connection pool (default: 10).
# Increase for high-traffic production deployments; keep low when Postgres has limited max_connections.
DATABASE_CONNECTION_LIMIT=10

# [optional] Seconds Prisma waits for a free connection before throwing (default: 10).
DATABASE_POOL_TIMEOUT=10

# ── Stellar Network ──────────────────────────────────────────
# [optional] Stellar network to connect to. Values: testnet | mainnet | futurenet (default: testnet)
STELLAR_NETWORK=testnet

# [required] Soroban RPC endpoint for the chosen network
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# [required] Horizon REST API endpoint for the chosen network
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# [required] Deployed ChainSettle contract ID (set after deploying chainsetttle-contract)
CHAINSETTTLE_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# [required] USDC token contract address on the chosen network
USDC_TOKEN_ADDRESS=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# [required] Backend Stellar account secret key (for reading contract events — does NOT hold user funds)
STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Email (Nodemailer) ───────────────────────────────────────
# [required] SMTP hostname
SMTP_HOST=smtp.gmail.com

# [optional] SMTP port (default: 587)
SMTP_PORT=587

# [required] SMTP login username
SMTP_USER=your-email@gmail.com

# [required] SMTP login password or app-password
SMTP_PASS=your-app-password

# [required] "From" address on outgoing emails
EMAIL_FROM=noreply@chainsetttle.com

# ── Rate Limiting ────────────────────────────────────────────
# [optional] Throttler window in seconds (default: 60)
THROTTLE_TTL=60

# [optional] Max requests per window per key (default: 100)
THROTTLE_LIMIT=100

# ── Redis ────────────────────────────────────────────────────
# [required] Redis connection URL (used for rate limiting and nonce storage)
REDIS_URL=redis://localhost:6379

# ── IPFS (Pinata — for pinning proof documents) ──────────────
# [optional] Public IPFS read gateway (default: https://gateway.pinata.cloud/ipfs)
IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# [optional] Pinata JWT. Get yours at https://app.pinata.cloud/keys
# Leave empty in development — stub CIDs are returned instead.
IPFS_API_KEY=your-pinata-jwt-token-here

# [optional] How often (ms) to re-check IPFS connectivity after startup (default: 60000)
IPFS_HEALTH_CHECK_INTERVAL_MS=60000

# ── Event Polling ────────────────────────────────────────────
# [optional] How often (ms) to poll Stellar for new contract events (default: 5000)
EVENT_POLLING_INTERVAL_MS=5000

# ── CORS ─────────────────────────────────────────────────────
# [optional] Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# [optional] Single-origin fallback (used only when ALLOWED_ORIGINS is not set)
CORS_ORIGIN=http://localhost:5173

# ── API Base URL ─────────────────────────────────────────────
# [optional] Base URL of this API — used in email verification links (default: http://localhost:3000)
API_BASE_URL=http://localhost:3000

# ── Development ──────────────────────────────────────────────
# [optional] Queries slower than this threshold (ms) are logged as warnings (default: 100)
SLOW_QUERY_THRESHOLD_MS=100
